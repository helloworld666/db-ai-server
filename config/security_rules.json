{
  "version": "1.0.0",
  "description": "SQL安全验证规则配置",
  "dangerous_keywords": [
    "DROP",
    "TRUNCATE",
    "ALTER",
    "CREATE",
    "GRANT",
    "REVOKE",
    "EXEC",
    "EXECUTE",
    "SHOW",
    "DESCRIBE"
  ],
  "allowed_sql_types": [
    "SELECT",
    "UPDATE",
    "INSERT",
    "DELETE"
  ],
  "forbidden_patterns": [
    {
      "pattern": ";\\s*\\w+",
      "description": "检测SQL注入：分号后紧跟关键字",
      "severity": "critical"
    },
    {
      "pattern": "--.*$",
      "description": "检测SQL注释注入",
      "severity": "high"
    },
    {
      "pattern": "/\\*.*\\*/",
      "description": "检测多行注释注入",
      "severity": "high"
    },
    {
      "pattern": "union\\s+select",
      "description": "检测UNION注入",
      "severity": "critical"
    },
    {
      "pattern": "\\bor\\s+\\d+\\s*=\\s*\\d+",
      "description": "检测OR注入攻击",
      "severity": "high"
    },
    {
      "pattern": "\\band\\s+\\d+\\s*=\\s*\\d+",
      "description": "检测AND注入攻击",
      "severity": "high"
    }
  ],
  "validation_rules": {
    "SELECT": {
      "max_return_rows": {
        "threshold": 1000,
        "action": "require_confirmation",
        "message": "预计返回行数超过 {threshold} 行，建议添加 LIMIT 限制"
      },
      "forbidden_columns": {
        "default_message": "查询不允许返回敏感字段: {columns}"
      },
      "require_where_for_large_tables": {
        "enabled": true,
        "threshold": 10000,
        "message": "大表查询建议包含WHERE条件以避免全表扫描"
      }
    },
    "UPDATE": {
      "require_where": {
        "enabled": true,
        "exceptions": ["configuration", "settings"],
        "message": "UPDATE语句建议包含WHERE条件"
      },
      "restricted_columns": {
        "default_message": "字段 {column} 受保护，不允许直接修改"
      },
      "max_updated_rows": {
        "threshold": 1000,
        "action": "require_confirmation",
        "message": "预计更新行数超过 {threshold} 行"
      }
    },
    "DELETE": {
      "require_where": {
        "enabled": true,
        "exceptions": [],
        "message": "DELETE语句必须包含WHERE条件"
      },
      "restricted_tables": {
        "default_message": "表 {table} 不允许执行DELETE操作"
      },
      "max_deleted_rows": {
        "threshold": 100,
        "action": "require_confirmation",
        "message": "预计删除行数超过 {threshold} 行"
      }
    },
    "INSERT": {
      "required_columns": {
        "default_message": "表 {table} 必须包含字段 {columns}"
      },
      "unique_columns": {
        "default_message": "字段 {column} 有唯一约束，请检查值是否重复"
      }
    }
  },
  "data_type_rules": {
    "enum_validators": {
      "default_message": "字段 {field} 的值必须为 {allowed_values} 之一"
    },
    "range_validators": {
      "default_message": "字段 {field} 的值必须在 {min} 到 {max} 之间"
    },
    "length_validators": {
      "default_message": "字段 {field} 的长度必须在 {min} 到 {max} 之间"
    },
    "pattern_validators": {
      "default_message": "字段 {field} 的值不符合格式要求: {pattern_description}"
    }
  },
  "cascading_checks": {
    "default_message": "存在关联记录，无法删除 {entity_type} {entity_id}"
  },
  "audit_rules": {
    "enabled": true,
    "log_all_operations": true,
    "log_high_risk_only": false,
    "include_sql": true,
    "include_user_context": true,
    "include_validation_results": true
  },
  "permission_rules": {
    "default_permission": "sql:execute",
    "role_permissions": {
      "default_message": "角色 {role} 没有 {permission} 权限"
    },
    "table_permissions": {
      "default_message": "对表 {table} 没有 {permission} 权限"
    }
  }
}
