{
  "server": {
    "name": "DB-AI-Server",
    "version": "1.0.0",
    "description": "数据库AI服务器，用于AI驱动的数据库SQL生成"
  },
  "inference_engine": {
   "type": "lmstudio",
    "base_url": "http://127.0.0.1:62666/v1",
    "model": "qwen2.5-coder-3b-instruct",
    "timeout": 120,
    "max_retries": 3,
    "temperature": 0.1,
    "num_ctx": 4096,
    "num_predict": 2048
  },
  "database": {
    "schema_file": "config/database_schema.json",
    "connection_string": "mysql://root:matrixdb@localhost:3306/erack",
    "enable_direct_query": true
  },
  "security": {
    "rules_file": "config/security_rules.json",
    "max_estimated_rows": 1000,
    "require_confirmation_threshold": 10,
    "enable_audit_log": true,
    "audit_log_file": "logs/audit.log"
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/mcp_server.log",
    "max_bytes": 10485760,
    "backup_count": 5
  },
  "features": {
    "enable_streaming": false,
    "enable_cache": true,
    "cache_ttl": 300,
    "enable_metrics": true
  }
}
