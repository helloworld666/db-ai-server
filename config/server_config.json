{
  "server": {
    "name": "db-ai-server",
    "version": "1.0.0",
    "description": "AI-powered database SQL generation server"
  },
  "database": {
    "connection_string": "mysql://root:matrixdb@localhost:3306/erack",
    "enable_direct_query": true
  },
  "inference_engine": {
    "type": "lmstudio",
    "base_url": "http://127.0.0.1:62666/v1",
    "model": "qwen2.5-coder-3b-instruct",
    "temperature": 0.7,
    "max_tokens": 2000
  },
  "security": {
    "allowed_ips": ["127.0.0.1", "::1"],
    "enable_rate_limit": true,
    "max_requests_per_minute": 60
  }
}